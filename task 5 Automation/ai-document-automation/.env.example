# Copy this file to .env and fill in your values.
# NEVER commit .env or share it on Google Drive with real keys inside.

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Sheets
GOOGLE_SHEET_NAME=Document Automation Log
# Path to service account JSON file (relative to project root or absolute)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service-account.json

# SMTP / Email (Gmail: use App Password with 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SENDER_EMAIL=your-email@gmail.com
RECEIVER_EMAIL=recipient@example.com

# Optional: override default upload settings
MAX_UPLOAD_SIZE_MB=10
