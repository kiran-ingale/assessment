# Environment and secrets — NEVER upload these to Google Drive or public repos
.env
.env.local
.env.*.local

# Google service account credentials
credentials/*.json
!credentials/.gitkeep
!credentials/README.md

# Uploaded PDFs may contain sensitive document content
uploads/*
!uploads/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/

# IDE and OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
